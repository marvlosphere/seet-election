# ─────────────────────────────────────────────────────────────
# SEET Election System — Environment Variables
# Copy this to .env.local for local development
# Add these to Vercel dashboard for production
# ─────────────────────────────────────────────────────────────

# Supabase (get from https://supabase.com/dashboard → your project → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Admin panel password (choose a strong password, share only with electoral committee)
ADMIN_KEY=your-strong-admin-password-here

# Termii SMS (Nigerian SMS gateway — get from https://termii.com)
TERMII_API_KEY=your-termii-api-key
TERMII_SENDER_ID=SEETVote

# Your deployed URL (used in SMS messages)
NEXT_PUBLIC_APP_URL=https://seet-election.vercel.app
